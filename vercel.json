{
  "rewrites": [

    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i)(googlebot|bingbot|adsbot|twitterbot|facebookexternalhit|linkedinbot|slackbot)"
        }
      ],
      "destination": "https://service.prerender.io/https://lovecalculator.space/$1?prerenderToken=xj9vSIiKlMS1iwqQF6NX"
    },

    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/Sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/ads.txt",
      "destination": "/ads.txt"
    },

    {
      "source": "/((?!assets|favicon|logo|manifest|og-image|placeholder|sitemap|robots|ads).*)",
      "destination": "/index.html"
    }

  ],

  "headers": [

    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },

    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }

  ]
}
