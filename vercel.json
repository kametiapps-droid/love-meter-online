{
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i)(googlebot|bingbot|yahoo|baiduspider|twitterbot|facebookexternalhit|linkedinbot|slackbot)"
        }
      ],
      "dest": "https://service.prerender.io/https://www.lovecalculator.space/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Prerender-Token",
          "value": "xj9vSIiKlMS1iwqQF6NX"
        }
      ]
    }
  ]
}
