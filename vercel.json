{
  "routes": [

    {
      "src": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i)(googlebot|bingbot|adsbot|twitterbot|facebookexternalhit|linkedinbot|slackbot)"
        }
      ],
      "dest": "https://service.prerender.io/https://www.lovecalculator.space/$1",
      "headers": {
        "X-Prerender-Token": "xj9vSIiKlMS1iwqQF6NX"
      }
    },

    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/Sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/ads.txt",
      "dest": "/ads.txt"
    },

    {
      "src": "/((?!assets|favicon|logo|manifest|og-image|placeholder|sitemap|robots|ads).*)",
      "dest": "/index.html"
    }

  ]
}
